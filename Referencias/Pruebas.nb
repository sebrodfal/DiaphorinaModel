              RowBox[{"x3", "[", "t", "]"}]}]}], ")"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"x1", "[", "0", "]"}], "==", "Di0"}], ",", 
