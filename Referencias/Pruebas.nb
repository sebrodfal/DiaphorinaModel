                    RowBox[{"b12", "*", 
                    RowBox[{"x2", "[", "t", "]"}]}], "+", 
                    RowBox[{"b13", "*", 
                    RowBox[{"x3", "[", "t", "]"}]}]}], ")"}]}]}], ")"}], "*", 
