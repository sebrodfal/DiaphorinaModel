    RowBox[{"b31", "=", "0.01"}], ";", 
    RowBox[{"a3", "=", "0.01"}], ";", 
    RowBox[{"c3", "=", "0.005"}], ";", "\[IndentingNewLine]", 
    RowBox[{"eqs", "=", 
