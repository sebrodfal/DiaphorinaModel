      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "5.5"}], ")"}], "/", "\[Delta]m"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"r2", "=", "\[Rho]"}], ";", 
    RowBox[{"b21", "=", 
     RowBox[{"-", "pi"}]}], ";", 
    RowBox[{"a2", "=", 
     RowBox[{"\[Rho]", "/", "K"}]}], ";", 
    RowBox[{"c2", "=", "0.005"}], ";", 
    RowBox[{"fo", "=", "2"}], ";", "\[IndentingNewLine]", 
    RowBox[{"r3", "=", 
