          RowBox[{"x2", "[", "0", "]"}], "==", "B0"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"x3", "[", "0", "]"}], "==", "x30"}]}], "}"}], ",", 
