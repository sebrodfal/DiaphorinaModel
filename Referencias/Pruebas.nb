Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "=", "0.49"}], ",", 
     RowBox[{"\[Phi]", "=", "4.09"}], ",", 
     RowBox[{"pd", "=", 
      RowBox[{"1", "/", "17.15"}]}], ",", 
     RowBox[{"\[Nu]", "=", "0.05"}], ",", 
     RowBox[{"\[Delta]i", "=", "0.139"}], ",", 
     RowBox[{"\[Delta]m", "=", "0.0272"}], ",", 
     RowBox[{"\[Rho]", "=", "0.1235"}], ",", 
     RowBox[{"pi", "=", "0.0005"}], ",", 
     RowBox[{"K", "=", "55"}], ",", 
     RowBox[{"Di0", "=", "140"}], ",", 
     RowBox[{"B0", "=", "8"}]}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"r1", "=", 
     RowBox[{
      RowBox[{"f", "*", "\[Phi]", "*", 
       RowBox[{"(", 
        RowBox[{"5.5", "*", 
         RowBox[{"pd", "/", "\[Delta]m"}]}], ")"}]}], " ", "-", 
      RowBox[{"(", 
       RowBox[{"\[Delta]i", "+", "\[Nu]"}], ")"}]}]}], ";", 
    RowBox[{"b12", "=", 
     RowBox[{"f", "*", "\[Phi]", "*", 
      RowBox[{"\[Nu]", "/", "\[Delta]m"}]}]}], ";", 
    RowBox[{"a1", "=", 
     RowBox[{"f", "*", "\[Phi]", "*", "\[Nu]", "*", 
      RowBox[{"pd", "/", "\[Delta]m"}]}]}], ";", 
    RowBox[{"c1", "=", "0.005"}], ";", 
    RowBox[{"c3", "=", "0"}], ";", "\[IndentingNewLine]", 
    RowBox[{"r2", "=", "\[Rho]"}], ";", 
    RowBox[{"b21", "=", 
     RowBox[{"-", "pi"}]}], ";", 
    RowBox[{"a2", "=", 
     RowBox[{"\[Rho]", "/", "K"}]}], ";", 
    RowBox[{"c2", "=", "0.005"}], ";", "\[IndentingNewLine]", 
    RowBox[{"eqs", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Di", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"f", " ", "\[Phi]", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"\[Nu]", " ", 
                 RowBox[{"Di", "[", "t", "]"}]}], "-", "5.5"}], ")"}], "/", 
              "\[Delta]m"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"B", "[", "t", "]"}], "-", 
              RowBox[{"pd", " ", 
               RowBox[{"Di", "[", "t", "]"}]}]}], ")"}]}], "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Delta]i", "+", "\[Nu]"}], ")"}], 
            RowBox[{"Di", "[", "t", "]"}]}]}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"x1", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{
            RowBox[{"x1", "[", "t", "]"}], "*", 
            RowBox[{"(", 
             RowBox[{"r1", "+", 
              RowBox[{"b12", "*", 
               RowBox[{"x2", "[", "t", "]"}]}], "-", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"a1", "+", 
                 RowBox[{"c1", "*", "b12", "*", 
                  RowBox[{"x2", "[", "t", "]"}]}]}], ")"}], "*", 
               RowBox[{"x1", "[", "t", "]"}]}]}], ")"}]}], "+", 
           RowBox[{
            RowBox[{"x2", "[", "t", "]"}], "*", "c3", "*", "f", " ", "\[Phi]",
             " ", "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "5.5"}], ")"}], "/", "\[Delta]m"}]}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"B", "'"}], "[", "t", "]"}], "==", 
           RowBox[{
            RowBox[{"\[Rho]", " ", 
             RowBox[{"B", "[", "t", "]"}], 
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{
                RowBox[{"B", "[", "t", "]"}], "/", "K"}]}], ")"}]}], "-", 
            RowBox[{"pi", " ", 
             RowBox[{"B", "[", "t", "]"}], "*", 
             RowBox[{"Di", "[", "t", "]"}]}]}]}], " ", "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"x2", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"x2", "[", "t", "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"r2", "+", 
             RowBox[{"b21", "*", 
              RowBox[{"x1", "[", "t", "]"}]}], "-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"a2", "+", 
                RowBox[{"c2", "*", "b21", "*", 
                 RowBox[{"x1", "[", "t", "]"}]}]}], ")"}], "*", 
              RowBox[{"x2", "[", "t", "]"}]}]}], ")"}]}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"x1", "[", "0", "]"}], "==", "Di0"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"x2", "[", "0", "]"}], "==", "B0"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"x1", ",", "x2"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "35"}], "}"}], ",", 
       RowBox[{"Method", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<TimeIntegration\>\"", "\[Rule]", "\"\<ExplicitRungeKutta\>\""}],
          "}"}]}]}], "]"}]}], ";", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x1", "[", "t", "]"}], ",", 
          RowBox[{"x2", "[", "t", "]"}]}], "}"}], "/.", "eqs"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "35"}], "}"}]}], "]"}]}]}], "]"}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 10001.},
