                RowBox[{"fo", "*", 
                 RowBox[{"Sin", "[", 
                  RowBox[{"2", "*", "\[Pi]", "*", 
                   RowBox[{"t", "/", "7"}]}], "]"}]}]}], ")"}]}], "+", 
             RowBox[{"b21", "*", 
              RowBox[{"x1", "[", "t", "]"}]}], "-", 
