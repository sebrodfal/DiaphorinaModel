     RowBox[{"\[Nu]", "=", "0.05"}], ",", 
     RowBox[{"\[Delta]i", "=", "0.139"}], ",", 
     RowBox[{"\[Delta]m", "=", 
      RowBox[{"25", "*", "0.0272"}]}], ",", 
     RowBox[{"\[Rho]", "=", "0.1235"}], ",", 
     RowBox[{"pi", "=", "0.0005"}], ",", 
     RowBox[{"K", "=", "55"}], ",", 
     RowBox[{"Di0", "=", "140"}], ",", 
     RowBox[{"B0", "=", "8"}], ",", 
     RowBox[{"x30", "=", "14"}], ",", 
     RowBox[{"tt", "=", "35"}]}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"r1", "=", 
     RowBox[{
      RowBox[{"f", "*", "\[Phi]", "*", 
       RowBox[{"(", 
        RowBox[{"5.5", "*", 
         RowBox[{"pd", "/", "\[Delta]m"}]}], ")"}]}], " ", "-", 
      RowBox[{"(", 
       RowBox[{"\[Delta]i", "+", "\[Nu]"}], ")"}]}]}], ";", 
    RowBox[{"b12", "=", 
