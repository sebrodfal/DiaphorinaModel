Cell["\<\
Modelo de la diapositiva 6/34 - tomando D' m[t] = cte, pero con un valor \
distinto de la cte en tres momentos distintos.\
\>", "Text",
 CellGroupingRules->{"GroupTogetherGrouping", 10000.},
 CellChangeTimes->{{3.947177767388771*^9, 3.947177799052*^9}, 
   3.952952520794524*^9},ExpressionUUID->"644638b2-ccb9-4924-9a06-\
7dec108cf5c9"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "=", "0.49"}], ",", 
     RowBox[{"\[Phi]", "=", "4.09"}], ",", 
     RowBox[{"pd", "=", 
      RowBox[{"1", "/", "17.15"}]}], ",", 
     RowBox[{"\[Nu]", "=", "0.05"}], ",", 
     RowBox[{"\[Delta]i", "=", "0.139"}], ",", 
     RowBox[{"\[Delta]m", "=", "0.0272"}], ",", 
     RowBox[{"\[Rho]", "=", "0.1235"}], ",", 
     RowBox[{"pi", "=", "0.0005"}], ",", 
     RowBox[{"K", "=", "55"}], ",", 
     RowBox[{"Di0", "=", "1"}], ",", 
     RowBox[{"B0", "=", "3"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"eqs", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Di", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"f", " ", "\[Phi]", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"\[Nu]", " ", 
                 RowBox[{"Di", "[", "t", "]"}]}], "-", 
                RowBox[{"Piecewise", "[", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"0", ",", 
                    RowBox[{"t", "<", "5"}]}], "}"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"3", ",", 
                    RowBox[{
                    RowBox[{"t", ">=", "5"}], "&&", 
                    RowBox[{"t", "<=", "15"}]}]}], "}"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"5.5", ",", 
                    RowBox[{"t", ">", "15"}]}], "}"}]}], "}"}], "]"}]}], 
               ")"}], "/", "\[Delta]m"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"B", "[", "t", "]"}], "-", 
              RowBox[{"pd", " ", 
               RowBox[{"Di", "[", "t", "]"}]}]}], ")"}]}], "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Delta]i", "+", "\[Nu]"}], ")"}], 
            RowBox[{"Di", "[", "t", "]"}]}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"B", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"\[Rho]", " ", 
            RowBox[{"B", "[", "t", "]"}], 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{
               RowBox[{"B", "[", "t", "]"}], "/", "K"}]}], ")"}]}], "-", 
           RowBox[{"pi", " ", 
            RowBox[{"B", "[", "t", "]"}], "*", 
            RowBox[{"Di", "[", "t", "]"}]}]}]}], ",", 
         RowBox[{
          RowBox[{"Di", "[", "0", "]"}], "==", "Di0"}], ",", 
         RowBox[{
          RowBox[{"B", "[", "0", "]"}], "==", "B0"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Di", ",", "Dm", ",", "B"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "50"}], "}"}], ",", 
       RowBox[{"Method", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<TimeIntegration\>\"", "\[Rule]", "\"\<ExplicitRungeKutta\>\""}],
          "}"}]}]}], "]"}]}], ";", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Di", "[", "t", "]"}], ",", 
          RowBox[{"B", "[", "t", "]"}]}], "}"}], "/.", "eqs"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "50"}], "}"}]}], "]"}]}]}], "]"}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 10000.},
 CellChangeTimes->{{3.9469976820779476`*^9, 3.946997743271984*^9}, {
   3.9469977908678284`*^9, 3.946997832701355*^9}, {3.9469978851415806`*^9, 
