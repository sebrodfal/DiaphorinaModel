        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"x1", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{
            RowBox[{"x1", "[", "t", "]"}], "*", 
            RowBox[{"(", 
             RowBox[{"r1", "+", 
              RowBox[{"b12", "*", 
