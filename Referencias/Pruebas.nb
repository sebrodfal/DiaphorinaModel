Cell[CellGroupData[{
Cell["Modelo de la diapositiva 6/34.", "Text",
 CellGroupingRules->{"GroupTogetherGrouping", 10000.},
 CellChangeTimes->{{3.947177675972904*^9, 3.947177693217765*^9}, 
   3.947177806484527*^9, 
   3.952952520793879*^9},ExpressionUUID->"c091e432-efc5-4039-9864-\
e9d4f8b3664b"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "=", "0.49"}], ",", 
     RowBox[{"\[Phi]", "=", "4.09"}], ",", 
     RowBox[{"pd", "=", 
      RowBox[{"1", "/", "17.15"}]}], ",", 
     RowBox[{"\[Nu]", "=", "0.05"}], ",", 
     RowBox[{"\[Delta]i", "=", "0.139"}], ",", 
     RowBox[{"\[Delta]m", "=", "0.0272"}], ",", 
     RowBox[{"\[Rho]", "=", "0.1235"}], ",", 
     RowBox[{"pi", "=", "0.0005"}], ",", 
     RowBox[{"K", "=", "55"}], ",", 
     RowBox[{"Di0", "=", "1"}], ",", 
     RowBox[{"Dm0", "=", "1"}], ",", 
     RowBox[{"B0", "=", "3"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"eqs", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Di", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"f", " ", "\[Phi]", " ", 
            RowBox[{"Dm", "[", "t", "]"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"B", "[", "t", "]"}], "-", 
              RowBox[{"pd", " ", 
               RowBox[{"Di", "[", "t", "]"}]}]}], ")"}]}], "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Delta]i", "+", "\[Nu]"}], ")"}], 
            RowBox[{"Di", "[", "t", "]"}]}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"Dm", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"\[Nu]", " ", 
            RowBox[{"Di", "[", "t", "]"}]}], "-", 
           RowBox[{"\[Delta]m", " ", 
            RowBox[{"Dm", "[", "t", "]"}]}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"B", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"\[Rho]", " ", 
            RowBox[{"B", "[", "t", "]"}], 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{
               RowBox[{"B", "[", "t", "]"}], "/", "K"}]}], ")"}]}], "-", 
           RowBox[{"pi", " ", 
            RowBox[{"B", "[", "t", "]"}], "*", 
            RowBox[{"Di", "[", "t", "]"}]}]}]}], ",", 
         RowBox[{
          RowBox[{"Di", "[", "0", "]"}], "==", "Di0"}], ",", 
         RowBox[{
          RowBox[{"Dm", "[", "0", "]"}], "==", "Dm0"}], ",", 
         RowBox[{
          RowBox[{"B", "[", "0", "]"}], "==", "B0"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Di", ",", "Dm", ",", "B"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "50"}], "}"}], ",", 
       RowBox[{"Method", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
         "\"\<TimeIntegration\>\"", "\[Rule]", "\"\<ExplicitRungeKutta\>\""}],
          "}"}]}]}], "]"}]}], ";", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Di", "[", "t", "]"}], ",", 
          RowBox[{"Dm", "[", "t", "]"}], ",", 
          RowBox[{"B", "[", "t", "]"}]}], "}"}], "/.", "eqs"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "50"}], "}"}]}], "]"}]}]}], "]"}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 10000.},
