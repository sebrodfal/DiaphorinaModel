              RowBox[{"{", 
               
               RowBox[{"\"\<r3\>\"", ",", "\"\<b31\>\"", ",", "\"\<a3\>\"", 
                ",", "\"\<c3\>\""}], "}"}], "->", "param3"}], "]"}]}]}], 
