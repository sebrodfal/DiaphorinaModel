Cell[CellGroupData[{

Cell["Multi System Model", "Section",
 CellChangeTimes->{{3.9894300110926733`*^9, 
  3.989430017883531*^9}},ExpressionUUID->"46b085c1-e277-4f47-a5c6-\
cec7c64db518"],

Cell[CellGroupData[{

Cell["System Equations", "Subsection",
 CellChangeTimes->{{3.9741451567092457`*^9, 3.9741451570536118`*^9}, {
  3.974146233726925*^9, 
  3.9741462534832287`*^9}},ExpressionUUID->"12081940-567e-405e-ad29-\
d247991942e9"],

Cell["\<\
SystemEvolve numerically integrates a system of nonlinear ordinary \
differential equations representing the population dynamics of a citrus \
agroecosystem, including Diaphorina citri (parasite), plant shoots, Tamarixia \
radiata (parasitoids), and external stimuli.\
\>", "Text",
 CellChangeTimes->{{3.973956163244528*^9, 3.973956197320105*^9}, 
   3.9741452737526817`*^9, {3.9741453716878433`*^9, 
   3.974145385539269*^9}},ExpressionUUID->"417c5ced-6705-4013-b711-\
e86cecaa2831"],

Cell["\<\
Periodic augmentative releases of parasitoids are implemented using \
WhenEvent, adding a fixed amount \[Delta] to the parasitoid population every \
T time units, while allowing the population to evolve continuously according \
to its intrinsic dynamics between releases.\
\>", "Text",
 CellChangeTimes->{{3.974145288606188*^9, 
  3.974145292501607*^9}},ExpressionUUID->"da53f2d7-8499-4d81-a747-\
e10f2aea0aa6"],

Cell["\<\
The system is solved using NDSolve with an explicit Runge\[Dash]Kutta time \
integration scheme, and the resulting population trajectories are visualized \
over the specified time horizon.\
\>", "Text",
 CellChangeTimes->{{3.974145294419601*^9, 
  3.9741452978920813`*^9}},ExpressionUUID->"f1e3e5a0-16f3-4eeb-948b-\
e387b91642bc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "SystemEvolve", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SystemEvolve", "[", 
   RowBox[{"\[Delta]_", ",", "T_", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"r1_", ",", "b12_", ",", "b13_", ",", "a1_", ",", "c1_"}], 
       "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r2_", ",", "b21_", ",", "b24_", ",", "a2_", ",", "c2_"}], 
       "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r3_", ",", "b31_", ",", "a3_", ",", "c3_"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r4_", ",", "b42_", ",", "a4_", ",", "c4_"}], "}"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"Di0_", ",", "B0_", ",", "x30_", ",", "x40_", ",", "tt_"}], 
     "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", "\n", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "eqs", ",", "x1", ",", "x2", ",", "x3", ",", "x4"}], 
     "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"eqs", "=", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"x1", "'"}], "[", "t", "]"}], "==", 
            RowBox[{
             RowBox[{"x1", "[", "t", "]"}], "*", 
             RowBox[{"(", 
              RowBox[{"r1", "+", 
               RowBox[{"b12", "*", 
                RowBox[{"x2", "[", "t", "]"}]}], "+", 
               RowBox[{"b13", "*", 
                RowBox[{"x3", "[", "t", "]"}]}], "-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"a1", "+", 
                  RowBox[{"c1", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"b12", "*", 
                    RowBox[{"x2", "[", "t", "]"}]}], "+", 
                    RowBox[{"b13", "*", 
                    RowBox[{"x3", "[", "t", "]"}]}]}], ")"}]}]}], ")"}], "*", 
                
                RowBox[{"x1", "[", "t", "]"}]}]}], ")"}]}]}], ")"}], ",", " ", 
          RowBox[{"(*", 
           RowBox[{"Diaphorina", " ", "citri"}], "*)"}], "\n", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"x2", "'"}], "[", "t", "]"}], "==", 
            RowBox[{
             RowBox[{"x2", "[", "t", "]"}], "*", 
             RowBox[{"(", 
              RowBox[{"r2", "+", 
               RowBox[{"b21", "*", 
                RowBox[{"x1", "[", "t", "]"}]}], "+", 
               RowBox[{"b24", "*", 
                RowBox[{"x4", "[", "t", "]"}]}], "-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"a2", "+", 
                  RowBox[{"c2", "*", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"b21", "*", 
                    RowBox[{"x1", "[", "t", "]"}]}], "+", 
                    RowBox[{"b24", "*", 
                    RowBox[{"x4", "[", "t", "]"}]}]}], ")"}]}]}], ")"}], "*", 
                
                RowBox[{"x2", "[", "t", "]"}]}]}], ")"}]}]}], ")"}], ",", " ", 
          RowBox[{"(*", 
           RowBox[{"Plant", " ", "shoots"}], "*)"}], "\n", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"x3", "'"}], "[", "t", "]"}], "==", 
            RowBox[{
             RowBox[{"x3", "[", "t", "]"}], "*", 
             RowBox[{"(", 
              RowBox[{"r3", "+", 
               RowBox[{"b31", "*", 
                RowBox[{"x1", "[", "t", "]"}]}], "-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"a3", "+", 
                  RowBox[{"c3", "*", "b31", "*", 
                   RowBox[{"x1", "[", "t", "]"}]}]}], ")"}], "*", 
                RowBox[{"x3", "[", "t", "]"}]}]}], ")"}]}]}], ")"}], ",", " ", 
          RowBox[{"(*", 
           RowBox[{"Tamarixia", " ", "radiata"}], "*)"}], "\n", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"x4", "'"}], "[", "t", "]"}], "==", 
            RowBox[{
             RowBox[{"x4", "[", "t", "]"}], "*", 
             RowBox[{"(", 
              RowBox[{"r4", "+", 
               RowBox[{"b42", "*", 
                RowBox[{"x2", "[", "t", "]"}]}], "-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"a4", "+", 
                  RowBox[{"c4", "*", "b42", "*", 
                   RowBox[{"x2", "[", "t", "]"}]}]}], ")"}], "*", 
                RowBox[{"x4", "[", "t", "]"}]}]}], ")"}]}]}], ")"}], ",", " ", 
          RowBox[{"(*", "Stimuli", "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"x1", "[", "0", "]"}], "==", "Di0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"x2", "[", "0", "]"}], "==", "B0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"x3", "[", "0", "]"}], "==", "x30"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"x4", "[", "0", "]"}], "==", "x40"}], ",", "\n", 
          RowBox[{"WhenEvent", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Mod", "[", 
               RowBox[{"t", ",", "T"}], "]"}], "==", "0"}], " ", "&&", " ", 
             RowBox[{"t", ">", "0"}]}], ",", " ", 
            RowBox[{
             RowBox[{"x3", "[", "t", "]"}], "->", 
             RowBox[{
              RowBox[{"x3", "[", "t", "]"}], "+", "\[Delta]"}]}]}], "]"}]}], 
         "\n", "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"x1", ",", "x2", ",", "x3", ",", "x4"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "tt"}], "}"}], ",", 
        RowBox[{"Method", "\[Rule]", 
         RowBox[{"{", 
          
          RowBox[{"\"\<TimeIntegration\>\"", 
           "\[Rule]", "\"\<ExplicitRungeKutta\>\""}], "}"}]}]}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"x1", "[", "t", "]"}], ",", 
           RowBox[{"x2", "[", "t", "]"}], ",", 
           RowBox[{"x3", "[", "t", "]"}], ",", 
           RowBox[{"x4", "[", "t", "]"}]}], "}"}], "/.", "eqs"}], "]"}], ",", 
       
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "tt"}], "}"}], ",", "\n", "\t", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Diaphorina citri (Parasite)\>\"", 
          ",", "\"\<Plant shoots\>\"", 
          ",", "\"\<Tamarixia radiata (Parasitoid)\>\"", 
          ",", "\"\<Stimuli\>\""}], "}"}]}], ",", "\n", "\t", 
       RowBox[{"PlotRange", "->", "All"}], ",", " ", 
       RowBox[{"PlotLabel", "->", "\"\<Generalized model\>\""}], ",", " ", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\"\<Time\>\"", "Input"], ",", " ", "\"\<Population\>\""}],
          "}"}]}]}], "]"}]}]}], "\n", "]"}]}]}], "Code",
 InitializationCell->False,
 CellChangeTimes->{{3.973690929603965*^9, 3.9736909319647627`*^9}, {
   3.9736911890517406`*^9, 3.973691253807733*^9}, {3.973691762576371*^9, 
   3.973691762719852*^9}, {3.973693955910207*^9, 3.973694068980207*^9}, {
